# ===== Target ditznesia =====
TARGET_BASE=https://ditznesia.com
# Endpoint infoOrder yang di-poll (status=Sukses = cuma yg udah dapet OTP)
INFO_ORDER_PATH=/orderv3?nomor=&status=Sukses&limit=100&page=1&action=infoOrder
POLL_INTERVAL_MS=5000

# ===== Cookie login ditznesia (1 akun) =====
# Ambil dari browser: F12 > Application > Cookies > ditznesia.com
MARS_PHPSESSID=
MARS_USER_ID=
MARS_EXPIRES_AT=
# cf_clearance OPSIONAL - browser bakal generate sendiri pas lewatin Cloudflare.
MARS_CF_CLEARANCE=

# ===== Tujuan push (Mars ingest) =====
INGEST_URL=https://api.clowatch.com/api/ingest
INGEST_SECRET=

# ===== Puppeteer =====
HEADLESS=true
# Kosongin buat pake Chromium bawaan puppeteer. Isi kalau mau pake Chrome sistem:
# CHROME_PATH=/usr/bin/google-chrome

# ===== Proxy (opsional tapi PENTING kalau IP VPS di-throttle Cloudflare) =====
# Residential/mobile proxy biar dapet IP fast-lane. Datacenter IP biasanya kena challenge terus.
# PROXY_SERVER=http://host:port
# PROXY_USER=
# PROXY_PASS=